# Cyrius Testing Reference
# Testing framework via assert.cyr + bench.cyr libraries.

# === Assertions ===
# include "lib/assert.cyr"
#
# assert(condition, "name")           — pass if condition == 1
# assert_eq(actual, expected, "name") — pass if equal, show got/expected on fail
# assert_neq(a, b, "name")           — pass if not equal
# assert_gt(a, b, "name")            — pass if a > b
# assert_summary()                    — print "N passed, M failed" and return fail count
#
# PATTERN: comparison expressions work in function args:
#   assert(x == 42, "check x");       # works — returns 0 or 1
#   assert(is_some(opt) == 1, "some"); # works

# === Test program structure ===
# fn test_feature() {
#     assert_eq(add(2, 2), 4, "add");
#     assert(is_valid(x) == 1, "valid");
#     return 0;
# }
#
# fn main() {
#     alloc_init();
#     test_feature();
#     return assert_summary();  # exit 0 if all pass
# }
# var exit_code = main();
# syscall(60, exit_code);

# === Benchmarking ===
# include "lib/bench.cyr"
#
# fn work() { ... return 0; }
# var b = bench_new("my_op");
# bench_run(b, &work, 10000);     # 10000 iterations
# bench_report(b);
# # Output: my_op: 407ns avg (min=390ns max=8us) [10000 iters]
#
# Manual timing:
# bench_start(b);
# ... code ...
# bench_stop(b);
#
# bench_avg_ns(b), bench_min_ns(b), bench_max_ns(b)
# Auto-scales output: ns → us → ms → s

# === Test runner ===
# Compile and run: cat test.cyr | cc2 > test && chmod +x test && ./test
# Exit code 0 = all pass, nonzero = failure count
