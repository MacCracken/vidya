# Testing — Cyrius reference (runnable)
# Patterns: assert, assert_eq, assert_neq, assert_gt, assert_summary

include "stage1/lib/string.cyr"
include "stage1/lib/fmt.cyr"
include "stage1/lib/alloc.cyr"
include "stage1/lib/assert.cyr"

fn add(a, b) { return a + b; }

fn test_assertions() {
    assert(1 == 1, "true");
    assert(0 == 0, "zero");
    assert_eq(add(2, 3), 5, "add");
    assert_neq(1, 2, "neq");
    assert_gt(10, 5, "gt");
    return 0;
}

fn test_comparisons_in_args() {
    var a = 42;
    # Comparisons work in function call arguments
    assert(a == 42, "comp in arg");
    assert(a > 0, "gt in arg");
    assert(a != 0, "neq in arg");
    return 0;
}

fn test_edge_cases() {
    assert_eq(0, 0, "zero eq");
    assert_eq(0 - 1, 0 - 1, "neg eq");
    assert_gt(1, 0, "one gt zero");
    assert_neq(0, 1, "zero neq one");
    return 0;
}

fn main() {
    alloc_init();
    test_assertions();
    test_comparisons_in_args();
    test_edge_cases();
    return assert_summary();
}
var exit_code = main();
syscall(60, exit_code);
