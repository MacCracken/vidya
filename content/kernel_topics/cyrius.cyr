# Kernel Topics -- Cyrius reference (compile-only)
# Patterns from AGNOS: PTE, GDT, IDT, TSS, SYSCALL, context switch, VFS
# Kernel code needs bare-metal mode; this tests the logic in userspace.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/assert.cyr"

# === Page Table Entry helpers ===
fn pte_build(phys, flags) { return (phys & 0x000FFFFFFFFFF000) | flags; }
fn pte_present(pte) { return pte & 1; }
fn pte_writable(pte) { return (pte >> 1) & 1; }
fn pte_user(pte) { return (pte >> 2) & 1; }
fn pte_addr(pte) { return pte & 0x000FFFFFFFFFF000; }

# 2MB huge page entry: phys | 0x83 (P+W+PS) or 0x87 (P+W+U+PS)
fn pde_2mb(phys, user) {
    var flags = 0x83;
    if (user == 1) { flags = 0x87; }
    return (phys & 0xFFFFFFFFFFE00000) | flags;
}

# === GDT helpers ===
fn gdt_present(e) { return (e >> 47) & 1; }
fn gdt_dpl(e) { return (e >> 45) & 3; }
fn gdt_long(e) { return (e >> 53) & 1; }

# GDT segment values from AGNOS
# 0x08: kernel CS  0x00AF9A000000FFFF
# 0x10: kernel DS  0x00CF92000000FFFF
# 0x18: user DS    0x00CFF2000000FFFF (DPL 3)
# 0x20: user CS    0x00AFFA000000FFFF (DPL 3, 64-bit)

# === IDT gate builder ===
fn idt_low(handler, sel, tattr) {
    var lo = handler & 0xFFFF;
    var s = sel << 16;
    var t = tattr << 40;
    var hi16 = ((handler >> 16) & 0xFFFF) << 48;
    return lo | s | t | hi16;
}

# === TSS helpers ===
# TSS descriptor is 16 bytes in 64-bit mode (spans 2 GDT slots)
# RSP0 at offset 4: kernel stack loaded on ring 3 -> ring 0 transition
fn tss_rsp0_offset() { return 4; }
fn tss_iopb_offset() { return 100; }

# === SYSCALL/SYSRET MSR values ===
# STAR MSR (0xC0000081):
#   [47:32] = kernel CS (0x08) -- for SYSCALL entry
#   [63:48] = user base (0x10) -- SYSRET: CS=base+16|3=0x23, SS=base+8|3=0x1B
fn star_value() { return 0x0010000800000000; }
# SFMASK (0xC0000084): clear IF (0x200) on syscall entry
fn sfmask_value() { return 0x200; }

# === Process context layout ===
# 168 bytes per process (21 fields x 8 bytes):
# pid(0) state(8) rsp(16) rip(24)
# rax(32) rbx(40) rcx(48) rdx(56) rsi(64) rdi(72) rbp(80)
# r8(88) r9(96) r10(104) r11(112) r12(120) r13(128) r14(136) r15(144)
# rflags(152) cr3(160)
fn proc_size() { return 168; }
fn proc_state_off() { return 8; }
fn proc_rsp_off() { return 16; }
fn proc_rip_off() { return 24; }
fn proc_cr3_off() { return 160; }

# === VFS file entry layout ===
# 32 bytes: type(0) pos(8) size(16) data(24)
# Types: 0=unused, 1=device, 2=memfile
fn vfs_entry_size() { return 32; }

# === Initrd format ===
# Header: magic(4) count(4)
# Entry: name(16) offset(8) size(8) = 32 bytes
fn initrd_magic() { return 0x52444E49; }
fn initrd_entry_size() { return 32; }

# === VFS file type constants (v1.1.0) ===
# Types: 0=unused, 1=device, 2=memfile, 3=signalfd, 4=epoll, 5=timerfd
fn vfs_type_device() { return 1; }
fn vfs_type_memfile() { return 2; }
fn vfs_type_signalfd() { return 3; }
fn vfs_type_epoll() { return 4; }
fn vfs_type_timerfd() { return 5; }

# === Syscall dispatch pattern ===
# Large if-chain dispatcher — each syscall number maps to a handler
fn syscall_dispatch(num, a1, a2, a3) {
    if (num == 0) { return 0; }          # exit
    if (num == 1) { return a2; }         # write (return count)
    if (num == 2) { return 42; }         # getpid
    if (num == 3) { return 0; }          # spawn
    if (num == 4) { return 0; }          # waitpid
    if (num == 5) { return a2; }         # read (return count)
    if (num == 6) { return 0; }          # close
    if (num == 7) { return 3; }          # open (return fd)
    return 0 - 1;                        # unknown syscall
}

# === Signal mask operations ===
fn sig_set(mask, signum) { return mask | (1 << signum); }
fn sig_clear(mask, signum) {
    # Use two's complement instead of ~ for kernel safety
    var bit = 1 << signum;
    var inv = 0 - 1 - bit;
    return mask & inv;
}
fn sig_test(mask, signum) { return (mask >> signum) & 1; }

# === Arch abstraction pattern ===
# Shared code calls these; each arch implements differently
# x86_64: arch_wait = hlt, arch_halt = cli; hlt
# aarch64: arch_wait = wfi, arch_halt = wfi (with interrupts masked)
fn arch_wait_sim() { return 0; }   # simulated — real version uses asm
fn arch_halt_sim() { return 0; }   # simulated — real version uses asm

# === 3-tier benchmark pattern with rdtsc ===
# Tier 1: Micro (single operation, <1000 cycles)
#   e.g., syscall_getpid 188cy, syscall_getuid 726cy
# Tier 2: Meso (alloc/free pair, 1000-10000 cycles)
#   e.g., pmm_alloc_free 1304cy, heap_32B 1207cy, heap_256B 3015cy
# Tier 3: Macro (multi-operation, >5000 cycles)
#   e.g., serial_putc 7510cy, vfs_open_read_close 5912cy, heap_4096B 26077cy
fn bench_tier(cycles) {
    if (cycles < 1000) { return 1; }
    if (cycles < 5000) { return 2; }
    return 3;
}

# === TCP connection state constants (v1.11.0) ===
fn tcp_state_closed() { return 0; }
fn tcp_state_syn_sent() { return 1; }
fn tcp_state_established() { return 2; }
fn tcp_state_fin_wait() { return 3; }

# === Pipe buffer pattern (VFS type 6) ===
# Circular buffer with head/tail stored in VFS entry
# Entry: { type=6, head(8), tail(8), data(8) }
# head advances on write, tail advances on read
# Buffer full when (head + 1) % size == tail
fn vfs_type_pipe() { return 6; }
fn pipe_buf_size() { return 4096; }

fn pipe_writable(head, tail, size) {
    var next = head + 1;
    if (next >= size) { next = 0; }
    if (next == tail) { return 0; }
    return 1;
}

fn pipe_readable(head, tail) {
    if (head == tail) { return 0; }
    return 1;
}

# === FAT16 boot sector field offsets ===
# Offsets from start of boot sector (512 bytes)
fn fat16_bytes_per_sector_off() { return 11; }  # 2 bytes
fn fat16_sectors_per_cluster_off() { return 13; }  # 1 byte
fn fat16_reserved_sectors_off() { return 14; }  # 2 bytes
fn fat16_num_fats_off() { return 16; }  # 1 byte
fn fat16_root_entry_count_off() { return 17; }  # 2 bytes
fn fat16_total_sectors_16_off() { return 19; }  # 2 bytes
fn fat16_fat_size_16_off() { return 22; }  # 2 bytes
fn fat16_dir_entry_size() { return 32; }

# === GRUB multiboot1 compatibility check ===
# Multiboot1 magic: 0x1BADB002 (in kernel image)
# Bootloader magic: 0x2BADB002 (in EAX at entry)
# Flags: bit 0 = page-align modules, bit 1 = provide memory map
fn multiboot1_magic() { return 0x1BADB002; }
fn multiboot1_bootloader_magic() { return 0x2BADB002; }
fn multiboot1_flags() { return 3; }  # page-align + meminfo

fn multiboot1_check(eax_value) {
    if (eax_value == 0x2BADB002) { return 1; }
    return 0;
}

# === Tests ===

fn test_pte() {
    var pte = pte_build(0x1000, 3);
    assert(pte_present(pte) == 1, "pte present");
    assert(pte_writable(pte) == 1, "pte writable");
    assert_eq(pte_addr(pte), 0x1000, "pte addr");
    # 2MB huge page
    var pde = pde_2mb(0x200000, 0);
    assert(pte_present(pde) == 1, "pde present");
    assert(pte_user(pde) == 0, "pde kernel");
    var pde_u = pde_2mb(0x200000, 1);
    assert(pte_user(pde_u) == 1, "pde user");
    return 0;
}

fn test_gdt() {
    var code64 = 0x00AF9A000000FFFF;
    assert(gdt_present(code64) == 1, "gdt present");
    assert_eq(gdt_dpl(code64), 0, "gdt dpl=0 kernel");
    assert(gdt_long(code64) == 1, "gdt long mode");
    # User code segment (DPL 3)
    var ucode = 0x00AFFA000000FFFF;
    assert_eq(gdt_dpl(ucode), 3, "gdt dpl=3 user");
    assert(gdt_long(ucode) == 1, "user long mode");
    return 0;
}

fn test_idt() {
    var handler = 0xFFFF80000010;
    var low = idt_low(handler, 8, 0x8E);
    assert_eq(low & 0xFFFF, 0x0010, "idt offset lo");
    assert_eq((low >> 16) & 0xFFFF, 8, "idt selector");
    return 0;
}

fn test_syscall_msrs() {
    var star = star_value();
    assert_eq((star >> 32) & 0xFFFF, 0x08, "star kernel cs");
    assert_eq((star >> 48) & 0xFFFF, 0x10, "star user base");
    assert_eq(sfmask_value(), 0x200, "sfmask clears IF");
    return 0;
}

fn test_proc_layout() {
    assert_eq(proc_size(), 168, "proc size");
    assert_eq(proc_cr3_off(), 160, "cr3 at 160");
    return 0;
}

fn test_initrd() {
    assert_eq(initrd_magic(), 0x52444E49, "initrd magic");
    assert_eq(initrd_entry_size(), 32, "initrd entry size");
    return 0;
}

fn test_vfs_types() {
    assert_eq(vfs_type_device(), 1, "vfs device");
    assert_eq(vfs_type_memfile(), 2, "vfs memfile");
    assert_eq(vfs_type_signalfd(), 3, "vfs signalfd");
    assert_eq(vfs_type_epoll(), 4, "vfs epoll");
    assert_eq(vfs_type_timerfd(), 5, "vfs timerfd");
    return 0;
}

fn test_syscall_dispatch() {
    assert_eq(syscall_dispatch(2, 0, 0, 0), 42, "getpid");
    assert_eq(syscall_dispatch(7, 0, 0, 0), 3, "open returns fd");
    assert_eq(syscall_dispatch(99, 0, 0, 0), 0 - 1, "unknown syscall");
    return 0;
}

fn test_signal_mask() {
    var mask = 0;
    mask = sig_set(mask, 2);
    assert_eq(sig_test(mask, 2), 1, "sig 2 set");
    assert_eq(sig_test(mask, 3), 0, "sig 3 not set");
    mask = sig_set(mask, 5);
    assert_eq(sig_test(mask, 5), 1, "sig 5 set");
    mask = sig_clear(mask, 2);
    assert_eq(sig_test(mask, 2), 0, "sig 2 cleared");
    assert_eq(sig_test(mask, 5), 1, "sig 5 still set");
    return 0;
}

fn test_bench_tier() {
    assert_eq(bench_tier(188), 1, "micro tier");
    assert_eq(bench_tier(1304), 2, "meso tier");
    assert_eq(bench_tier(7510), 3, "macro tier");
    return 0;
}

fn test_tcp_states() {
    assert_eq(tcp_state_closed(), 0, "tcp closed");
    assert_eq(tcp_state_syn_sent(), 1, "tcp syn_sent");
    assert_eq(tcp_state_established(), 2, "tcp established");
    assert_eq(tcp_state_fin_wait(), 3, "tcp fin_wait");
    return 0;
}

fn test_pipe_buffer() {
    assert_eq(vfs_type_pipe(), 6, "pipe type");
    assert_eq(pipe_buf_size(), 4096, "pipe buf size");
    # Empty buffer: head == tail
    assert_eq(pipe_readable(0, 0), 0, "empty not readable");
    assert_eq(pipe_writable(0, 0, 4096), 1, "empty is writable");
    # Buffer with data: head > tail
    assert_eq(pipe_readable(5, 0), 1, "has data");
    # Buffer full: (head + 1) % size == tail
    assert_eq(pipe_writable(4095, 0, 4096), 0, "full not writable");
    return 0;
}

fn test_fat16_offsets() {
    assert_eq(fat16_bytes_per_sector_off(), 11, "bps offset");
    assert_eq(fat16_root_entry_count_off(), 17, "root entries offset");
    assert_eq(fat16_dir_entry_size(), 32, "dir entry 32B");
    return 0;
}

fn test_multiboot1_compat() {
    assert_eq(multiboot1_magic(), 0x1BADB002, "mb1 magic");
    assert_eq(multiboot1_bootloader_magic(), 0x2BADB002, "mb1 bl magic");
    assert_eq(multiboot1_check(0x2BADB002), 1, "mb1 check pass");
    assert_eq(multiboot1_check(0), 0, "mb1 check fail");
    return 0;
}

fn main() {
    alloc_init();
    test_pte();
    test_gdt();
    test_idt();
    test_syscall_msrs();
    test_proc_layout();
    test_initrd();
    test_vfs_types();
    test_syscall_dispatch();
    test_signal_mask();
    test_bench_tier();
    test_tcp_states();
    test_pipe_buffer();
    test_fat16_offsets();
    test_multiboot1_compat();
    return assert_summary();
}
var exit_code = main();
syscall(60, exit_code);
